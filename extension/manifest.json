{
  "manifest_version": 3,
  "name": "Odelink Live Control",
  "version": "1.0.0",
  "description": "Odelink SaaS platformu için gerçek zamanlı canlı analitik ve CEO bildirimleri.",
  "permissions": [
    "notifications",
    "storage",
    "alarms",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.shopier.com/*"],
      "js": ["content-shopier.js"]
    }
  ],
  "host_permissions": [
    "https://*.odelink.shop/*",
    "https://www.shopier.com/*",
    "http://localhost:3001/*"
  ]
}
