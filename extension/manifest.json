{
  "manifest_version": 3,
  "name": "Odelink Omni-Scraper v6.0",
  "version": "6.0.0",
  "description": "Ultra-Professional 3D/4D Product Scraper for Odelink Studio",
  "permissions": ["activeTab", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icon.png", "48": "icon.png", "128": "icon.png" }
  },
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" },
  "content_scripts": [
    {
      "matches": ["https://*.shopier.com/*"],
      "js": ["content-shopier.js"],
      "run_at": "document_idle"
    }
  ]
}
