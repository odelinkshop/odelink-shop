{
  "name": "odelink-desktop",
  "version": "1.0.0",
  "description": "Odelink CEO Command Center - Windows Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack:win": "electron-packager . Odelink --platform=win32 --arch=x64 --icon=icon.ico --overwrite --out=dist",
    "build:setup": "npm run pack:win && node buildInstaller.js"
  },
  "author": "Odelink Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-winstaller": "^5.4.0"
  }
}
