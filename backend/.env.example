# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=odelink_shop
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

ADMIN_CLAIM_EMAIL=odelink@admin.com

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Stripe Configuration (Eski - Kullanılmıyor)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Dodo Payments Configuration (Aktif Ödeme Sistemi)
DODO_PAYMENTS_API_KEY=your_dodo_api_key_here
DODO_WEBHOOK_SECRET=your_dodo_webhook_secret_here
TEST_MODE=false

# Dodo Payments Product IDs (Dodo Payments dashboard'dan alınacak)
DODO_PRODUCT_STANDARD_MONTHLY=prod_standard_monthly
DODO_PRODUCT_PROFESSIONAL_YEARLY=prod_professional_yearly
DODO_PRODUCT_AD_BASIC=prod_ad_basic
DODO_PRODUCT_AD_PROFESSIONAL=prod_ad_professional
DODO_PRODUCT_AD_PREMIUM=prod_ad_premium

# Puppeteer Configuration
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox

# Image Optimization (Cloudinary)
# Ücretsiz hesap: https://cloudinary.com/users/register/free
# Cloud name'inizi buraya yazın (opsiyonel, yoksa demo cloud kullanılır)
CLOUDINARY_CLOUD_NAME=demo

# Cloudflare API (Otomatik DNS kaydı için)
# API Token: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Zone ID: Cloudflare Dashboard → odelink.shop → Overview → Zone ID
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# Shopier API (Ürün listesi için)
# Personal Access Token: https://shopier.com/m/pat.php
SHOPIER_API_TOKEN=your_shopier_pat_token_here
