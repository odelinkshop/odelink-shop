{
  "name": "odelink-backend",
  "version": "1.0.0",
  "description": "Odelink.shop backend API",
  "main": "server.js",
  "scripts": {
    "postinstall": "node -e \"const path=require('path'); const {execSync}=require('child_process'); const v=String(process.env.BUILD_FRONTEND||'').toLowerCase(); if(v==='true'){const fe=path.join(__dirname,'..','frontend'); execSync('npm install',{cwd:fe,stdio:'inherit'}); execSync('npm run build',{cwd:fe,stdio:'inherit'});} else {console.log('Skipping frontend build (set BUILD_FRONTEND=true to enable).');}\"",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@sparticuz/chromium": "^131.0.1",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "cssnano": "^7.1.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "liquidjs": "^10.25.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "puppeteer-core": "^23.11.1",
    "qs": "^6.15.0",
    "sharp": "^0.34.5",
    "stripe": "^14.9.0",
    "terser": "^5.46.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "e-commerce",
    "shopier",
    "api",
    "nodejs"
  ],
  "author": "Murat Bayram",
  "license": "MIT"
}
