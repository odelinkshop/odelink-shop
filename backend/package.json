{
  "name": "odelink-backend",
  "version": "1.0.0",
  "description": "Odelink.shop backend API",
  "main": "server.js",
  "scripts": {
    "postinstall": "node -e \"const path=require('path'); const {execSync}=require('child_process'); const v=String(process.env.BUILD_FRONTEND||'').toLowerCase(); if(v==='true'){const fe=path.join(__dirname,'..','frontend'); execSync('npm install',{cwd:fe,stdio:'inherit'}); execSync('npm run build',{cwd:fe,stdio:'inherit'});} else {console.log('Skipping frontend build (set BUILD_FRONTEND=true to enable).');}\"",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^8.26.0",
    "@sentry/profiling-node": "^8.26.0",
    "@sparticuz/chromium": "^123.0.0",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.4.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "puppeteer": "^23.11.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qs": "^6.15.0",
    "rate-limit-redis": "^4.2.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "e-commerce",
    "shopier",
    "api",
    "nodejs"
  ],
  "author": "Murat Bayram",
  "license": "MIT"
}
